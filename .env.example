# Guitar Detection System — environment variables
# See DESIGN.md §5.7 for the canonical reference.
# Copy to `.env` and edit as needed; never commit `.env`.

# --- Shared ---
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO

# --- Gateway ---
MAX_INGEST_FPS=30
JPEG_QUALITY=75
SESSION_IDLE_TIMEOUT_S=10

# --- Worker ---
DETECT_CONF=0.35
DETECT_IOU=0.5
DETECT_IMGSZ=416
CLIP_INPUT_SIZE=224
VOTE_WINDOW=15
VOTE_STABLE_MIN=8
VOTE_STABLE_CONF=0.55
MODELS_DIR=/models
PROMPTS_FILE=/config/prompts.yaml
OPENVINO_DEVICE=CPU
# OPENVINO_THREADS: 0 = auto
OPENVINO_THREADS=0

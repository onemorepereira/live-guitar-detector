# Dev image for the gateway.
#
# Differs from the prod image: source comes in via bind-mount from the
# host so uvicorn --reload picks up edits without a rebuild. Layer
# ordering still avoids busting the (large) dep install on source
# edits: pyproject metadata first, deps from pyproject second, source
# last.

FROM docker.io/library/python:3.11-slim AS dev

ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# aiortc runtime + the gcc the dev workflow occasionally needs for
# debugging native wheels. ffmpeg makes one-off codec experiments cheap.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libavformat59 \
        libavcodec59 \
        libavutil57 \
        libswscale6 \
        libsrtp2-1 \
        libopus0 \
        libvpx7 \
        ffmpeg \
        gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- layer: pyproject only (caches dep install) ---
COPY pyproject.toml /app/pyproject.toml

# --- layer: runtime + dev deps from pyproject, no app code ---
RUN python -c "import tomllib, sys; \
        data = tomllib.load(open('pyproject.toml','rb')); \
        deps = list(data['project']['dependencies']); \
        deps += list(data['project']['optional-dependencies'].get('dev', [])); \
        sys.stdout.write('\n'.join(deps))" > /tmp/deps.txt \
    && pip install -r /tmp/deps.txt \
    && rm /tmp/deps.txt

# --- layer: app + tests (shadowed by bind-mount in compose) ---
# The dev compose bind-mounts services/gateway/app onto /app/app so
# uvicorn --reload sees host edits. The COPY here lets the image run
# standalone for smoke-testing without compose.
COPY app /app/app
COPY tests /app/tests
RUN pip install --no-deps -e .

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
